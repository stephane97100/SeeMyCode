rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default catch-all security net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create, update: if isSignedIn() && userId == request.auth.uid && incoming().uid == request.auth.uid;
    }

    // Snippets Collection Rules
    match /snippets/{snippetId} {
      allow get: if true;
      allow list: if true; // Search queries depend on broad list search with where filters

      allow create: if incoming().code is string 
                   && incoming().code.size() <= 1048576 // limit 1MB code text
                   && incoming().language is string
                   && incoming().language.size() <= 128
                   && (!("ownerId" in incoming()) || (isSignedIn() && incoming().ownerId == request.auth.uid));

      allow update: if (
        // Enforce structural metadata immutability
        (!("ownerId" in existing()) || ("ownerId" in incoming() && incoming().ownerId == existing().ownerId)) &&
        incoming().createdAt == existing().createdAt &&
        incoming().expiresAt == existing().expiresAt &&
        incoming().code is string &&
        incoming().code.size() <= 1048576 &&
        
        // Typing lock check for concurrent edits protection
        (
          // Case A: Nobody holds lock or it has expired, allowing a new editor to claim it
          existing().activeEditorUid == null ||
          request.time.toMillis() > existing().activeEditorExpires ||
          
          // Case B: Current editor matching the active editor tries to update content
          (
            existing().activeEditorUid == (isSignedIn() ? request.auth.uid : incoming().activeEditorUid)
          ) ||
          
          // Case C: Explicitly claiming or releasing the lock
          (
            incoming().activeEditorUid != existing().activeEditorUid
          )
        )
      );

      allow delete: if false; // Avoid snippet deletions to preserve historical links

      // Real-time Presence Sub-collection
      match /presence/{presenceId} {
        allow read: if true; // Other users in same snippet room can see who is active
        allow write, delete: if (
          (isSignedIn() && presenceId == request.auth.uid && incoming().uid == request.auth.uid) ||
          (!isSignedIn() && presenceId.startsWith("guest_") && incoming().uid == presenceId)
        );
      }
    }
  }
}
